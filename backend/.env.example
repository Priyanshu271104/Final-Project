# ---- SerpApi (already set up) ----
SERPAPI_KEY=your_serpapi_key_here

# ---- CORS (prod only; leave blank for localhost default) ----
# Comma-separated list of allowed frontend origins
# ALLOWED_ORIGINS=https://your-frontend-domain.com

# ---- Firebase Admin (for cron + server-side Firestore access) ----
# Get these from Firebase Console -> Project Settings -> Service Accounts
# -> "Generate new private key" -> open the downloaded JSON
FIREBASE_PROJECT_ID=pricelens-b802e
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@pricelens-b802e.iam.gserviceaccount.com
# Paste the full private key on one line, with actual \n between lines replaced by literal \n
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQ...\n-----END PRIVATE KEY-----\n"

# ---- Gmail SMTP (for sending alert emails) ----
# 1. Enable 2FA on the Gmail account you want to send from
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an "App password" for "Mail"
# 4. Paste below (16 chars, no spaces)
GMAIL_USER=youralerts@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# ---- Cron shared secret (for /api/cron/check-prices) ----
# Generate any random long string; whatever calls the cron endpoint
# must send this in the "x-cron-secret" header
CRON_SECRET=replace-with-long-random-string

# ---- Alert tuning (optional) ----
# Minimum % drop vs baseline price to trigger an email
PRICE_DROP_THRESHOLD_PCT=5
# Max SerpApi calls per cron run (guard against quota burn)
CRON_BATCH_SIZE=5
