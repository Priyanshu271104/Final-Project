rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User profile document: readable/writable only by the owner.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasOnly(['uid', 'email', 'displayName', 'createdAt'])
                    && request.resource.data.uid == userId
                    && request.resource.data.email is string
                    && request.resource.data.displayName is string
                    && request.resource.data.displayName.size() <= 100;
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.uid == userId;
      allow delete: if false;

      // Wishlist items: scoped to the owning user.
      match /wishlist/{productId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
                      && request.auth.uid == userId
                      && isValidWishlistItem(request.resource.data);
        // Updates from the client are limited to notifyEmail, targetPrice, and
        // resetting lastTargetNotifiedPrice — so clients can't tamper with
        // baselinePrice or the drop-tracking fields the cron manages.
        allow update: if request.auth != null
                      && request.auth.uid == userId
                      && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['notifyEmail', 'targetPrice', 'lastTargetNotifiedPrice'])
                      && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['notifyEmail'])
                          || request.resource.data.notifyEmail is bool)
                      && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['targetPrice'])
                          || request.resource.data.targetPrice == null
                          || (request.resource.data.targetPrice is number
                              && request.resource.data.targetPrice >= 0
                              && request.resource.data.targetPrice < 100000000))
                      && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['lastTargetNotifiedPrice'])
                          || request.resource.data.lastTargetNotifiedPrice == null);
      }
    }

    // Deny all other paths by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }

  function isValidWishlistItem(data) {
    return data.keys().hasAll(['id', 'name', 'currentPrice', 'baselinePrice'])
      && data.name is string && data.name.size() <= 500
      && data.currentPrice is number && data.currentPrice >= 0 && data.currentPrice < 100000000
      && data.baselinePrice is number && data.baselinePrice >= 0 && data.baselinePrice < 100000000
      && (!('image' in data) || (data.image is string && data.image.size() <= 2000))
      && (!('rating' in data) || data.rating is number)
      && (!('reviews' in data) || data.reviews is number)
      && (!('category' in data) || (data.category is string && data.category.size() <= 100))
      && (!('notifyEmail' in data) || data.notifyEmail is bool)
      && (!('lastCheckedPrice' in data) || data.lastCheckedPrice is number)
      && (!('lastNotifiedPrice' in data) || data.lastNotifiedPrice == null || data.lastNotifiedPrice is number)
      && (!('targetPrice' in data) || data.targetPrice == null || (data.targetPrice is number && data.targetPrice >= 0 && data.targetPrice < 100000000))
      && (!('lastTargetNotifiedPrice' in data) || data.lastTargetNotifiedPrice == null || data.lastTargetNotifiedPrice is number)
      && (!('addedAt' in data) || data.addedAt is string);
  }
}
